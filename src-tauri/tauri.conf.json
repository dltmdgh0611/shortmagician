{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shortmagician",
  "version": "0.2.3",
  "identifier": "com.hvnsoft.shortmagician",
  "build": {
    "beforeDevCommand": "yarn dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "shortmagician",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": [
      "resources/fonts/*"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "languages": ["Korean", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1QzJDNTBCOTZDNDk3RDUKUldUVmw4U1dDOFhDeFduRkw5TllEd0thT0d0QTRQWnRUZTBlS1ZWZ3pKSUVKYXRRYmx4am45c3gK",
      "endpoints": [
        "https://gist.githubusercontent.com/dltmdgh0611/d5b9c835e537ecef12fea82115d70ddb/raw/latest.json"
      ]
    }
  }
}
