{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shortmagician",
  "version": "0.1.0",
  "identifier": "com.hvnsoft.shortmagician",
  "build": {
    "beforeDevCommand": "yarn dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "shortmagician",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": [
      "resources/fonts/*"
    ]
  }
}
