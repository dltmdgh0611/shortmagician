HOST=0.0.0.0
PORT=8000

# Optional: Firebase Admin (for Firestore access)
# Path to Firebase service account key JSON file
GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json
# Firebase project ID from Firebase Console
FIREBASE_PROJECT_ID=your_project_id

# Instagram 링크 파싱용 인증 (Instagram 링크 사용 시 필수)
# 브라우저에서 Instagram 로그인 > F12 DevTools > Application > Cookies > instagram.com > sessionid 값 복사
INSTAGRAM_SESSION_ID=your_instagram_session_id

# OpenAI API (Whisper STT + GPT Translation)
OPENAI_API_KEY=your_openai_api_key

# Google Cloud (TTS) - uses same service account as Firebase
# GOOGLE_CLOUD_PROJECT=your_project_id (defaults to FIREBASE_PROJECT_ID)
