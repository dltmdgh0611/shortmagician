{
  "name": "shortmagician-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for ShortMagician",
  "engines": { "node": "20" },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
